<!DOCTYPE html>
<html>
<head>
    <title>Teacher Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="d-flex">

    <!-- Sidebar -->
    <div class="bg-dark text-white p-4" style="width: 260px; min-height: 100vh;">
        <h3 class="fw-bold">Unisync</h3>
        <p class="text-secondary">Teacher Panel</p>

        <hr class="border-secondary">

        <p>Welcome</p>
        <h5><%= user.name %></h5>

        <a href="/logout" class="btn btn-danger w-100 mt-4">
            Logout
        </a>
    </div>

    <!-- Main -->
    <div class="flex-grow-1 p-4">

        <h2 class="mb-4">Teacher Dashboard</h2>

        <!-- Search -->
        <div class="card shadow border-0 mb-4">
            <div class="card-body">
                <form method="GET" action="/teacher/dashboard">
                    <div class="input-group">
                        <input
                            type="text"
                            name="search"
                            value="<%= search %>"
                            class="form-control"
                            placeholder="Search by student name or registration"
                        >
                        <button class="btn btn-dark">
                            Search
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Add Record -->
        <div class="card shadow border-0 mb-4">
            <div class="card-body">

                <h4>Add / Update Academic Record</h4>

                <form action="/teacher/add-result" method="POST" enctype="multipart/form-data">

                    <input
                        type="text"
                        name="student_name"
                        class="form-control mb-3"
                        placeholder="Student Name"
                        required
                    >

                    <input
                        type="text"
                        name="registration_no"
                        class="form-control mb-3"
                        placeholder="Registration Number"
                        required
                    >

                    <input
                        type="file"
                        name="photo"
                        class="form-control mb-3"
                    >

                    <input
                        type="text"
                        name="semester"
                        class="form-control mb-3"
                        placeholder="Semester"
                        required
                    >

                    <input
                        type="number"
                        step="0.01"
                        name="cgpa"
                        class="form-control mb-3"
                        placeholder="CGPA"
                        required
                    >

                    <button class="btn btn-success w-100">
                        Save Record
                    </button>

                </form>

            </div>
        </div>

        <!-- Records Table -->
        <div class="card shadow border-0">
            <div class="card-body">

                <h4>Academic Records</h4>

                <table class="table table-hover align-middle mt-3">
                    <thead class="table-dark">
                        <tr>
                            <th>Photo</th>
                            <th>Name</th>
                            <th>Registration</th>
                            <th>Semester</th>
                            <th>CGPA</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% students.forEach(student => { %>
                            <tr>

                                <td>
                                    <% if(student.photo){ %>
                                        <img
                                            src="/uploads/<%= student.photo %>"
                                            width="50"
                                            height="50"
                                            class="rounded-circle"
                                        >
                                    <% } else { %>
                                        No Photo
                                    <% } %>
                                </td>

                                <td><%= student.student_name %></td>
                                <td><%= student.registration_no %></td>
                                <td><%= student.semester %></td>
                                <td><%= student.cgpa %></td>

                                <td>
                                    <form
    action="/teacher/delete-record/<%= student.id %>"
    method="POST"
    onsubmit="return confirm('Are you sure you want to delete this record?');"
>
    <button class="btn btn-danger btn-sm">
        Delete
    </button>
</form>
                                </td>

                            </tr>
                        <% }) %>

                    </tbody>
                </table>

            </div>
        </div>

    </div>

</div>

</body>
</html>