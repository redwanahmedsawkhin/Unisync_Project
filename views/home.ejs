<!DOCTYPE html>
<html>
<head>
    <title>Unisync</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<nav class="navbar navbar-dark bg-primary shadow">
    <div class="container">
        <span class="navbar-brand fw-bold fs-3">Unisync</span>
    </div>
</nav>

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold">University Management Portal</h1>
        <p class="text-muted">Student • Teacher • Admin Management System</p>
    </div>

    <div class="row g-4 justify-content-center">

        <div class="col-md-3">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h4>Student</h4>
                    <a href="/signup" class="btn btn-success w-100 mt-3">Signup</a>
                    <a href="/student-login" class="btn btn-outline-success w-100 mt-2">Login</a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h4>Teacher</h4>
                    <a href="/teacher-login" class="btn btn-warning w-100 mt-3">Login</a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h4>Admin</h4>
                    <a href="/admin-login" class="btn btn-danger w-100 mt-3">Login</a>
                </div>
            </div>
        </div>

    </div>

</div>

</body>
</html>