<!DOCTYPE html>
<html>
<head>
    <title>Student Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="d-flex">

    <!-- Sidebar -->
    <div class="bg-success text-white p-4" style="width:260px; min-height:100vh;">
        <h3 class="fw-bold">Unisync</h3>
        <p>Student Panel</p>

        <hr>

        <h5><%= user.name %></h5>
        <p><%= user.registration_no %></p>

        <a href="/logout" class="btn btn-danger w-100 mt-4">
            Logout
        </a>
    </div>

    <!-- Main -->
    <div class="flex-grow-1 p-4">

        <h2 class="mb-4">Student Dashboard</h2>

        <% if(message){ %>
            <div class="alert alert-success">
                <%= message %>
            </div>
        <% } %>

        <% if(error){ %>
            <div class="alert alert-danger">
                <%= error %>
            </div>
        <% } %>

        <div class="card shadow border-0 mb-4">
            <div class="card-body text-center">

                <% if(results.length > 0 && results[0].photo){ %>
                    <img
                        src="/uploads/<%= results[0].photo %>"
                        width="120"
                        height="120"
                        class="rounded-circle mb-3"
                    >
                <% } %>

                <h3><%= user.name %></h3>
                <p>Email: <%= user.email %></p>
                <p>Registration: <%= user.registration_no %></p>

            </div>
        </div>

        <!-- Change Password -->
        <div class="card shadow border-0 mb-4">
            <div class="card-body">

                <h4>Change Password</h4>

                <form action="/student/change-password" method="POST">

                    <input
                        type="password"
                        name="currentPassword"
                        class="form-control mb-3"
                        placeholder="Current Password"
                        required
                    >

                    <input
                        type="password"
                        name="newPassword"
                        class="form-control mb-3"
                        placeholder="New Password"
                        required
                    >

                    <button class="btn btn-primary">
                        Change Password
                    </button>

                </form>

            </div>
        </div>

        <!-- Results -->
        <div class="card shadow border-0">
            <div class="card-body">

                <h4>Your Academic Results</h4>

                <table class="table table-hover mt-3">
                    <thead class="table-success">
                        <tr>
                            <th>Semester</th>
                            <th>CGPA</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% if(results.length === 0){ %>
                            <tr>
                                <td colspan="2" class="text-center">
                                    No result found
                                </td>
                            </tr>
                        <% } %>

                        <% results.forEach(result => { %>
                            <tr>
                                <td><%= result.semester %></td>
                                <td><%= result.cgpa %></td>
                            </tr>
                        <% }) %>

                    </tbody>
                </table>

            </div>
        </div>

    </div>

</div>

</body>
</html>